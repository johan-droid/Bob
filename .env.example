# ============================================
# Bob - Master Environment Configuration
# ============================================
# This file is for LOCAL DEVELOPMENT ONLY
# DO NOT commit this file to Git
# For Heroku, set these via: heroku config:set KEY=value
# ============================================

# ============================================
# GitHub Configuration
# ============================================

# GitHub Personal Access Token (PAT)
# Required scopes: repo, issues:write, pull_requests:write
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Target Repositories (comma-separated)
# Format: owner/repo-name,owner/repo-name
# Example: acme-corp/api-service,acme-corp/web-app,acme-corp/mobile-app
TARGET_REPOS=org/repo-alpha,org/repo-beta,org/repo-gamma

# ============================================
# GitHub OAuth App Configuration
# ============================================

# GitHub OAuth App Credentials
# Create OAuth App at: https://github.com/settings/developers
# 
# For Local Development:
#   Homepage URL: http://localhost:5000
#   Callback URL: http://localhost:5000/callback/github
#
# For Heroku Production:
#   Homepage URL: https://your-app-name.herokuapp.com
#   Callback URL: https://your-app-name.herokuapp.com/callback/github

GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# ============================================
# Flask Configuration
# ============================================

# Flask Secret Key (for session management)
# Generate with: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your_secret_key_here_generate_with_python_command

# ============================================
# Server Configuration
# ============================================

# Server Port
# Local: 5000 (default)
# Heroku: Set automatically by Heroku
PORT=5000

# Scan Interval (seconds)
# How often to scan repositories in background
# Default: 300 (5 minutes)
# Recommended: 300-600 for production
SCAN_INTERVAL=300

# ============================================
# Optional: Database Configuration (Future)
# ============================================

# PostgreSQL Database URL (for production persistence)
# Heroku sets this automatically when you add Heroku Postgres
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# Optional: Logging Configuration
# ============================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# ============================================
# Optional: Feature Flags
# ============================================

# Enable/disable background scanning
# ENABLE_BACKGROUND_SCAN=true

# Enable/disable GitHub OAuth (for testing)
# ENABLE_OAUTH=true

# ============================================
# Development Notes
# ============================================
# 
# 1. Copy this file to .env for local development
# 2. Never commit .env to Git (it's in .gitignore)
# 3. For Heroku deployment, set these via CLI:
#    heroku config:set GITHUB_TOKEN=your_token
#    heroku config:set TARGET_REPOS=org/repo1,org/repo2
#    heroku config:set GITHUB_CLIENT_ID=your_client_id
#    heroku config:set GITHUB_CLIENT_SECRET=your_secret
#    heroku config:set SECRET_KEY=$(python -c "import os; print(os.urandom(24).hex())")
#
# 4. To view Heroku config:
#    heroku config
#
# 5. To update a variable:
#    heroku config:set VARIABLE_NAME=new_value
#
# ============================================
