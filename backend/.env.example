# GitHub Personal Access Token (PAT)
# Required scopes: repo, issues:write, pull_requests:write
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=replace_with_github_pat

# Target Repositories (comma-separated)
# Format: owner/repo-name,owner/repo-name
# Example: acme-corp/api-service,acme-corp/web-app,acme-corp/mobile-app
TARGET_REPOS=org/repo-alpha,org/repo-beta,org/repo-gamma

# GitHub OAuth App Credentials
# Create OAuth App at: https://github.com/settings/developers
# Homepage URL: https://your-app.herokuapp.com
# Callback URL: https://your-app.herokuapp.com/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace_with_generated_64_hex_secret

# Optional separate token encryption key. If blank, SECRET_KEY is used.
TOKEN_ENCRYPTION_KEY=

# GitHub Webhook secret. Required in production.
WEBHOOK_SECRET=

# Local-only override to skip webhook verification during development.
ALLOW_UNSIGNED_WEBHOOKS=0

# Local-only migration override for old plaintext database tokens.
ALLOW_LEGACY_PLAINTEXT_TOKENS=0

# Server Configuration
# Port for Flask server (Heroku sets this automatically)
PORT=5000

# Scan Interval (seconds)
# How often to scan repositories in background (default: 300 = 5 minutes)
SCAN_INTERVAL=300
